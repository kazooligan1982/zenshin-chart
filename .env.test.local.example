# Copy this file to .env.test.local and fill in real values.
# .env.test.local is gitignored and only used by Playwright E2E tests.

# Test user credentials. The user must exist in the live Supabase project
# (wglutqoufuvnzmkruewg) and belong to at least one workspace with editor
# permissions or higher. Recommendation: create a dedicated user
# (e.g. e2e-test@u2c.io) and a dedicated workspace named "[E2E] Sandbox".
E2E_TEST_EMAIL=e2e-test@example.com
E2E_TEST_PASSWORD=changeme

# Optional: override the base URL Playwright tests against. Defaults to
# http://localhost:3000 (the dev server Playwright auto-starts).
# PLAYWRIGHT_BASE_URL=http://100.124.87.5:3000
